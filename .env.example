# band platform urls (env var names unchanged from sdk docs)
THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket
BAND_HANDOFF_TIMEOUT=600

# per-agent band credentials (preferred — from app.band.ai)
BAND_GATEWAY_API_KEY=
BAND_GATEWAY_AGENT_ID=
BAND_RECEPTIONIST_API_KEY=
BAND_RECEPTIONIST_AGENT_ID=
BAND_INTAKE_API_KEY=
BAND_INTAKE_AGENT_ID=
BAND_BRIEF_API_KEY=
BAND_BRIEF_AGENT_ID=

# dev fallback: copy agent_config.yaml.example → agent_config.yaml locally (gitignored)

# featherless ai (open-source model inference)
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL_TRIAGE=Qwen/Qwen2.5-72B-Instruct
FEATHERLESS_MODEL_ACTION=Qwen/Qwen2.5-72B-Instruct

# aml api — set for demo to earn "Best Use of AI/ML API" (verification primary path)
AML_API_KEY=
AML_BASE_URL=https://api.aimlapi.com/v1
AML_MODEL_VERIFICATION=

# umls (optional)
UMLS_API_KEY=

# web search
TAVILY_API_KEY=tvly-your_free_tavily_key_here
BRAVE_API_KEY=

# medical apis
SEMANTIC_SCHOLAR_API_KEY=your_free_semantic_scholar_key

# reddit (optional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# research email (openalex polite pool)
RESEARCH_EMAIL=your_email@example.com
OPENALEX_EMAIL=your_email@example.com

# set to 1 to use in-process langgraph instead of band (dev fallback)
ELIXIR_LEGACY_GRAPH=0

# llm provider: featherless (hackathon demo) | bedrock (local dev)
LLM_PROVIDER=featherless

# aws bedrock (when LLM_PROVIDER=bedrock)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
ORCHESTRATOR_MODEL_ID=amazon.nova-lite-v1:0
